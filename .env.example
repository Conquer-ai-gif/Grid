# ============================================================
# YOOM AI — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in all values
# ============================================================

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Clerk Authentication ───────────────────────────────────
# Get from: https://clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_d2lzZS1zbHVnLTg2LmNsZXJrLmFjY291bnRzLmRldiQ"
CLERK_SECRET_KEY="sk_test_Tt5IzhT8BdoSI2i4SSBVjImU04ZdfXJ7C9wcTCOX3y"

# ─── Stream Video ────────────────────────────────────────────
# Get from: https://getstream.io → Dashboard → App → API Keys
NEXT_PUBLIC_STREAM_API_KEY=xxxx
STREAM_SECRET_KEY=xxxx

# ─── Supabase ────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# ─── Inngest ─────────────────────────────────────────────────
# Get from: https://app.inngest.com → Your App → Keys
INNGEST_EVENT_KEY=xxxx
INNGEST_SIGNING_KEY=signkey-xxxx

# ─── Wit.ai ──────────────────────────────────────────────────
# Get from: https://wit.ai → Your App → Settings → Server Access Token
WIT_AI_TOKEN=xxxx

# ─── OpenRouter ──────────────────────────────────────────────
# Get from: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-xxxx

# ─── Upstash Redis (Rate Limiting) ───────────────────────────
# Get from: https://upstash.com → Redis → Your DB → REST API
# OPTIONAL: if not set, rate limiting is disabled in dev mode
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ─── Admin Dashboard ─────────────────────────────────────────
# Set this to any strong password you want to use to log into /admin
# Example: ADMIN_SECRET_PASSWORD=MyStr0ng!AdminPass2024
# NEVER commit this to git — keep it only in .env.local
ADMIN_SECRET_PASSWORD=your_strong_admin_password_here
